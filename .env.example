# Ejemplo de variables de entorno
# Copiar a .env y llenar con valores reales

# Configuración de la aplicación
APP_ENV=development
APP_DEBUG=true

# Ruta de datos
DATA_PATH=data/Churn_Modelling.csv
LOG_LEVEL=INFO

# Base de datos (para futuras integraciones)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=admin
# DB_PASSWORD=
# DB_NAME=churn_db

# API keys (si se integra con servicios)
# SENDGRID_API_KEY=
# SLACK_WEBHOOK_URL=

# Email
# EMAIL_SENDER=noreply@ejemplo.com
# EMAIL_PASSWORD=

# Otros
# API_TIMEOUT=30
# MAX_UPLOAD_SIZE=200
